# Function to auto-start Lemonade server in Termux
function init_clip_sync() {
  # Check if we are running inside the Termux environment
    if [ -n "$TERMUX_VERSION" ] || [[ "$PREFIX" == *com.termux* ]]; then
        # Check if a lemonade server process is already running
        if ! pgrep -x "lemonade" > /dev/null; then
            echo "Starting Lemonade clipboard server in background..."
            # Starts server using config from ~/.config/lemonade.toml
            lemonade server > /dev/null 2>&1 & 
            disown
        else
            echo "Lemonade server is already running."
        fi
    fi
}
