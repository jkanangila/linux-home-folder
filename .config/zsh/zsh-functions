# Safely sources a configuration file if it physically exists on the disk
# Arguments: $1 - Relative path to the file from the $ZDOTDIR root
function zsh_add_file() {
    [[ -f "$ZDOTDIR/$1" ]] && source "$ZDOTDIR/$1"
}

# Dynamically loads or installs GitHub-hosted Zsh plugins
# Arguments: $1 - The GitHub repository name formatted as "username/repo"
function zsh_add_plugin() {
    local plugin_repo="$1"
    local plugin_name="${plugin_repo#*/}" # Efficiently strips everything before the "/"
    local plugin_dir="$ZDOTDIR/plugins/$plugin_name"

    if [[ -d "$plugin_dir" ]]; then
        # Dynamically probe and source the primary plugin entry point script
        zsh_add_file "plugins/$plugin_name/$plugin_name.plugin.zsh" || \
        zsh_add_file "plugins/$plugin_name/$plugin_name.zsh"
    else
        echo "Installing plugin: $plugin_name..."
        git clone --depth=1 "https://github.com/$plugin_repo" "$plugin_dir"
        
        # Load the newly cloned plugin instantly
        zsh_add_file "plugins/$plugin_name/$plugin_name.plugin.zsh" || \
        zsh_add_file "plugins/$plugin_name/$plugin_name.zsh"
    fi
}


